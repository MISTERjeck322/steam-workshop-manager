{
  "manifest_version": 3,
  "name": "Steam Workshop Pirate",
  "version": "1.3",
  "description": "Adds a download button to Steam Workshop and dynamically loads localizations.",
  "content_scripts": [
    {
      "matches": [
        "*://steamcommunity.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["locales.json"],
      "matches": ["*://steamcommunity.com/*"]
    }
  ]
}